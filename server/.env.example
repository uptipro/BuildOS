# ─────────────────────────────────────────────────────────────────────────────
# BuildOS API — environment template. Copy to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma).
DATABASE_URL="postgresql://user:password@host:5432/buildos?sslmode=require"
# HTTP port the API listens on.
PORT=3001
NODE_ENV=development
# Public URL of the frontend (used for CORS + password-reset / invite links).
FRONTEND_URL=http://localhost:5173

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# CHANGE THESE IN PRODUCTION — long, random, secret values.
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=60m
# Email of the bootstrap admin account that is auto-granted all apps.
SEED_ADMIN_EMAIL=admin@buildos.ng

# ── Email (Resend) ───────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_FROM="BuildOS <no-reply@buildos.ng>"
RESEND_API_KEY=

# ── Redis (OPTIONAL) ─────────────────────────────────────────────────────────
# Powers caching, BullMQ background jobs (email delivery), distributed rate
# limiting and session/token revocation. If BOTH REDIS_URL and REDIS_HOST are
# unset, all of these degrade gracefully (in-memory cache, inline email send,
# in-memory rate limiting, revocation disabled) and the app runs normally.
#
# Easiest: a single connection URL (use rediss:// for TLS).
# REDIS_URL=redis://default:password@localhost:6379
#
# Or discrete fields:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=false
#
# Namespace applied to BullMQ/session keys (optional).
# REDIS_KEY_PREFIX=buildos:
