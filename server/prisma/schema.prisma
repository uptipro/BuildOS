  rentalSupplier     String?
  estimatedDays      Int      @default(0)
  totalEstimatedCost Float    @default(0)
  status             String   @default("Available")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([projectId])
}
