// ─────────────── CONSTRUCTION PROJECT SETUP WIZARD ───────────────
// Persists the multi-step "Project Setup" wizard payload for a construction
// project. Each step's data is stored as a JSON column to avoid coupling the
// wizard's evolving shape to a wide relational schema.

model ProjectSetup {
  id             String   @id @default(cuid())
  projectId      String   @unique
  // Step payloads
  basicInfo      Json? // name, client, projectManager, dates, contractType, contractingModel, location, siteAddress, description, clusterId
  projectType    Json? // sector, category, descriptor, structureEntries[]
  humanResources Json? // staff[], contractors[], vendors[] (+ representatives), humanResourceRoles[]
  dailyReporting Json? // contributorMode, contributorEmployeeIds[], contributorRepIds[], recurringReportTasks[]
  materials      Json? // projectMaterials[]
  equipment      Json? // projectEquipment[]
  calendar       Json? // workingDays, hours, holidays[], shutdowns[]
  schedule       Json? // tasks[], resourceAssignments[]
  // Baseline lock / audit
  setupComplete  Boolean  @default(false)
  setupLocked    Boolean  @default(false)
  currentStep    Int      @default(0)
  completedSteps Int[]    @default([])
  auditLog       Json? // [{ action, performedBy, performedAt, reason }]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

